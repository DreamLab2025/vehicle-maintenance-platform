{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext:l} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Aspire": {
    "Seq": {
      "Logs": {
        "TimeoutMilliseconds": 10000,
        "BatchExportProcessorOptions": {
          "ScheduledDelayMilliseconds": 5000,
          "MaxExportBatchSize": 512,
          "ExporterTimeoutMilliseconds": 30000,
          "MaxQueueSize": 2048
        }
      }
    }
  },
  "ESms": {
    "ApiKey": "YOUR_ESMS_API_KEY_HERE",
    "SecretKey": "YOUR_ESMS_SECRET_KEY_HERE",
    "BaseUrl": "https://rest.esms.vn/MainService.svc/json/",
    "BrandName": "Verendar",
    "SmsType": 2,
    "Timeout": 30,
    "Sandbox": 1
  },
  "Resend": {
    "FromEmail": "noreply@verendar.vn",
    "FromName": "Verendar",
    "Timeout": 30,
    "EnableTracking": true,
    "TemplateBasePath": "Templates/Email",
    "EnableTemplateCache": true,
    "TemplateCacheExpirationMinutes": 60,
    "UseDatabaseTemplates": false
  },
  "JwtBearer": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS_LONG",
    "Issuer": "https://your-domain.com",
    "Audience": "https://your-domain.com",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 0
  }
}
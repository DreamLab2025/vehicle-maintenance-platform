{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext:l} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Aspire": {
    "Seq": {
      "Logs": {
        "TimeoutMilliseconds": 10000,
        "BatchExportProcessorOptions": {
          "ScheduledDelayMilliseconds": 5000,
          "MaxExportBatchSize": 512,
          "ExporterTimeoutMilliseconds": 30000,
          "MaxQueueSize": 2048
        }
      }
    }
  },
  "NotificationApp": {
    "BaseUrl": "https://www.verendar.vn",
    "LoginPath": "/login",
    "BookingDetailPathFormat": "/bookings/{0}",
    "ProposalPathFormat": "/user/proposal/{0}",
    "UserVehicleMaintenancePathFormat": "/",
    "UserVehicleOdometerPathFormat": "/user-vehicles/{0}/odometer",
    "UserVehiclesFallbackPath": "/user-vehicles"
  },
  "Email": {
    "EnableRealSend": false,
    "Resend": {
      "FromEmail": "noreply@verendar.vn",
      "FromName": "Verendar",
      "Timeout": 30,
      "EnableTracking": true,
      "TemplateBasePath": "Templates/Email",
      "EnableTemplateCache": true,
      "TemplateCacheExpirationMinutes": 60,
      "UseDatabaseTemplates": false
    }
  },
  "JwtBearer": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS_LONG",
    "Issuer": "https://your-domain.com",
    "Audience": "https://your-domain.com",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 0
  }
}

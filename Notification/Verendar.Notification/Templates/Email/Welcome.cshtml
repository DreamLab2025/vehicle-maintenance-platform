@using Verendar.Notification.Application.Dtos.Email
@model WelcomeEmailModel
@{
    Layout = "_Layout";
    ViewBag.Title = "Chào mừng đến với Verendar";
}

<h2>Xin chào @Model.FullName!</h2>

<p>Chúng tôi rất vui mừng được chào đón bạn đến với <strong>Verendar</strong> - nền tảng quản lý bảo dưỡng xe hơi hàng đầu.</p>

<p>Bạn đã đăng ký thành công vào ngày <strong>@Model.RegistrationDate.ToString("dd/MM/yyyy")</strong>.</p>

@if (!string.IsNullOrEmpty(Model.WelcomeMessage))
{
    <p>@Model.WelcomeMessage</p>
}

<p>Bắt đầu khám phá các tính năng tuyệt vời của chúng tôi:</p>
<ul>
    <li>📋 Quản lý lịch bảo dưỡng xe</li>
    <li>🔔 Nhận thông báo nhắc nhở</li>
    <li>📊 Theo dõi lịch sử bảo dưỡng</li>
    <li>💰 Quản lý chi phí</li>
</ul>

<p>Nếu bạn có bất kỳ câu hỏi nào, đừng ngần ngại liên hệ với chúng tôi.</p>

<p>Trân trọng,<br>
<strong>Đội ngũ Verendar</strong></p>

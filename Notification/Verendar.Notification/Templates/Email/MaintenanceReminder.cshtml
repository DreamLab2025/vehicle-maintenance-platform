@using Verendar.Notification.Application.Dtos.Email
@using Microsoft.AspNetCore.Html
@model MaintenanceReminderEmailModel
@{
    Layout = "_Layout";
    ViewBag.Title = Model.Title;
}
@functions {
    static IHtmlContent Raw(string? s) => new HtmlString(s ?? string.Empty);
}

<h2>@Model.Title</h2>

<p>Xin chào @(string.IsNullOrEmpty(Model.UserName) ? "bạn" : Model.UserName),</p>

@if (Model.IsUrgent)
{
    <p style="color: #dc3545; font-weight: 600;">Xe của bạn có linh kiện đã đến mức <strong>khẩn cấp</strong> cần thay thế. Bạn sẽ nhận được email nhắc nhở hằng ngày cho đến khi bạn cập nhật đã thay linh kiện.</p>
}
else
{
    <p>Xe của bạn có linh kiện cần chú ý bảo dưỡng/thay thế (<strong>@Model.LevelName</strong>).</p>
}

<p><strong>Các linh kiện cần chú ý:</strong></p>
<table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
    <thead>
        <tr style="background-color: #f8f9fa;">
            <th style="padding: 10px; text-align: left; border: 1px solid #dee2e6;">Linh kiện</th>
            <th style="padding: 10px; text-align: left; border: 1px solid #dee2e6;">Xe</th>
            <th style="padding: 10px; text-align: right; border: 1px solid #dee2e6;">Số km hiện tại</th>
            <th style="padding: 10px; text-align: right; border: 1px solid #dee2e6;">Cần thay trước</th>
            <th style="padding: 10px; text-align: center; border: 1px solid #dee2e6;">Còn lại</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td style="padding: 10px; border: 1px solid #dee2e6;">@item.PartCategoryName</td>
                <td style="padding: 10px; border: 1px solid #dee2e6;">@(item.VehicleDisplayName ?? "—")</td>
                <td style="padding: 10px; text-align: right; border: 1px solid #dee2e6;">@item.CurrentOdometer.ToString("N0") km</td>
                <td style="padding: 10px; text-align: right; border: 1px solid #dee2e6;">@item.TargetOdometer.ToString("N0") km</td>
                <td style="padding: 10px; text-align: center; border: 1px solid #dee2e6;">@item.PercentageRemaining.ToString("F0")%</td>
            </tr>
        }
    </tbody>
</table>

<p>Vui lòng vào app cập nhật sau khi thay linh kiện để dừng nhắc nhở.</p>

@if (!string.IsNullOrEmpty(Model.ActionUrl) && !string.IsNullOrEmpty(Model.ActionText))
{
    <p style="text-align: center; margin-top: 24px;">
        <a href="@Model.ActionUrl" class="button">@Model.ActionText</a>
    </p>
}

<p>Trân trọng,<br><strong>Đội ngũ Verendar</strong></p>

@using Verendar.Notification.Application.Dtos.Email
@using Microsoft.AspNetCore.Html
@model OtpEmailModel
@{
    Layout = "_Layout";
    ViewBag.Title = "Mã xác thực OTP";
}
@functions {
    static IHtmlContent Raw(string? s) => new HtmlString(s ?? string.Empty);
}

<h2>Mã xác thực OTP của bạn</h2>

<p>Xin chào @Model.UserName,</p>

<p>Bạn đã yêu cầu mã xác thực OTP cho <strong>@Model.OtpType</strong>.</p>

<div class="otp-code">
    @Model.OtpCode
</div>

<p><strong>Lưu ý quan trọng:</strong></p>
<ul>
    <li>Mã OTP này có hiệu lực trong <strong>@Model.ExpiryMinutes phút</strong></li>
    <li>Mã sẽ hết hạn vào lúc <strong>@Model.ExpiryTime.ToString("HH:mm dd/MM/yyyy")</strong></li>
    <li>Không chia sẻ mã này với bất kỳ ai</li>
    <li>Nếu bạn không yêu cầu mã này, vui lòng bỏ qua email này</li>
</ul>

<p style="color: #dc3545; font-size: 14px;">
    ⚠️ Cảnh báo: Verendar sẽ không bao giờ yêu cầu bạn cung cấp mã OTP qua email hoặc điện thoại.
</p>

<p>Trân trọng,<br>
    <strong>Đội ngũ Verendar</strong>
</p>

@using Verendar.Notification.Application.Dtos.Email
@using Microsoft.AspNetCore.Html
@model PasswordResetEmailModel
@{
    Layout = "_Layout";
    ViewBag.Title = "Đặt lại mật khẩu";
}
@functions {
    static IHtmlContent Raw(string? s) => new HtmlString(s ?? string.Empty);
}

<h2>Đặt lại mật khẩu</h2>

<p>Xin chào @Model.UserName,</p>

<p>Chúng tôi nhận được yêu cầu đặt lại mật khẩu cho tài khoản của bạn.</p>

<p>Nhấp vào nút bên dưới để đặt lại mật khẩu:</p>

<p style="text-align: center;">
    <a href="@Model.ResetUrl" class="button">Đặt lại mật khẩu</a>
</p>

<p>Hoặc sao chép và dán liên kết sau vào trình duyệt của bạn:</p>
<p style="word-break: break-all; color: #667eea;">@Model.ResetUrl</p>

<p><strong>Lưu ý:</strong></p>
<ul>
    <li>Liên kết này có hiệu lực trong <strong>@Model.ExpiryMinutes phút</strong></li>
    <li>Liên kết sẽ hết hạn vào lúc <strong>@Model.ExpiryTime.ToString("HH:mm dd/MM/yyyy")</strong></li>
    <li>Nếu bạn không yêu cầu đặt lại mật khẩu, vui lòng bỏ qua email này</li>
    <li>Mật khẩu của bạn sẽ không thay đổi cho đến khi bạn tạo mật khẩu mới</li>
</ul>

<p style="color: #dc3545; font-size: 14px;">
    ⚠️ Cảnh báo: Nếu bạn không yêu cầu đặt lại mật khẩu, vui lòng liên hệ với chúng tôi ngay lập tức.
</p>

<p>Trân trọng,<br>
    <strong>Đội ngũ Verendar</strong>
</p>

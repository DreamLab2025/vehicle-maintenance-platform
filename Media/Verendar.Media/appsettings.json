{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext:l} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Aspire": {
    "Seq": {
      "Logs": {
        "TimeoutMilliseconds": 10000,
        "BatchExportProcessorOptions": {
          "ScheduledDelayMilliseconds": 5000,
          "MaxExportBatchSize": 512,
          "ExporterTimeoutMilliseconds": 30000,
          "MaxQueueSize": 2048
        }
      }
    }
  },
  "JwtBearer": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS_LONG",
    "Issuer": "https://your-domain.com",
    "Audience": "https://your-domain.com",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 0
  },
  "FileUpload": {
    "MaxFileSizeByContentType": {
      "image/jpeg": 5242880,
      "image/jpg": 5242880,
      "image/png": 5242880,
      "image/gif": 5242880,
      "image/webp": 5242880,
      "image/bmp": 5242880,
      "image/svg+xml": 5242880,
      "video/mp4": 20971520,
      "video/mpeg": 20971520,
      "video/quicktime": 20971520,
      "video/x-msvideo": 20971520,
      "video/webm": 20971520,
      "video/x-flv": 20971520,
      "application/pdf": 10485760
    },
    "DefaultMaxFileSize": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/jpg",
      "image/png",
      "image/gif",
      "image/webp",
      "image/bmp",
      "image/svg+xml",
      "video/mp4",
      "video/mpeg",
      "video/quicktime",
      "video/x-msvideo",
      "video/webm",
      "video/x-flv",
      "application/pdf"
    ]
  },
  "S3Settings": {
    "BucketName": "verendar",
    "Region": "ap-southeast-1",
    "CloudFrontUrl": "https://d3iova6424vljy.cloudfront.net"
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext:l} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Aspire": {
    "Seq": {
      "Logs": {
        "TimeoutMilliseconds": 10000,
        "BatchExportProcessorOptions": {
          "ScheduledDelayMilliseconds": 5000,
          "MaxExportBatchSize": 512,
          "ExporterTimeoutMilliseconds": 30000,
          "MaxQueueSize": 2048
        }
      }
    }
  },
  "AiProvider": "Bedrock",
  "Gemini": {
    "ApiEndpoint": "https://generativelanguage.googleapis.com/v1beta",
    "DefaultModel": "gemini-2.5-flash",
    "MaxRetries": 3,
    "TimeoutSeconds": 180,
    "RequestsPerMinute": 60,
    "RequestsPerDay": 1500,
    "MaxConcurrentRequests": 5,
    "DefaultParameters": {
      "MaxTokens": 8192,
      "Temperature": 0.7,
      "TopP": 0.95,
      "TopK": 40
    },
    "Pricing": {
      "InputCostPer1MTokens": 0.075,
      "OutputCostPer1MTokens": 0.30
    }
  },
  "Bedrock": {
    "Region": "us-east-1",
    "DefaultModel": "anthropic.claude-3-5-sonnet-20240620-v1:0",
    "MaxRetries": 3,
    "TimeoutSeconds": 60,
    "DefaultParameters": {
      "MaxTokens": 8192,
      "Temperature": 0.7,
      "TopP": 0.95,
      "TopK": 40
    },
    "Pricing": {
      "InputCostPer1MTokens": 3.00,
      "OutputCostPer1MTokens": 15.00
    }
  },
  "JwtBearer": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS_LONG",
    "Issuer": "https://your-domain.com",
    "Audience": "https://your-domain.com",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 30
  },
  "VehicleService": {
    "BaseUrl": "https://localhost:8002"
  },
  "MediaService": {
    "BaseUrl": "https://localhost:8003"
  },
  "PromptVersioning": {
    "MaxVersionsPerPrompt": 20
  }
}
{
  "ignorePatterns": [
    "**/bin/**",
    "**/obj/**",
    "**/.vs/**",
    "**/.git/**",
    "**/Migrations/**",
    "**/TestResults/**",
    "**/coverage/**",
    "**/*.suo",
    "**/*.user",
    "**/*.lock.json",
    "**/node_modules/**"
  ],
  "permissions": {
    "allow": [
      "Bash(node -e \":*)"
    ]
  }
}

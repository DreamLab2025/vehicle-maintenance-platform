# Copy to .env.dev and fill values. Used by: docker-compose -f docker-compose.dev.yml --env-file .env.dev

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=verendar
IDENTITY_SERVICE_DATABASE=Identities
VEHICLE_SERVICE_DATABASE=Vehicles
MEDIA_SERVICE_DATABASE=Media
NOTIFICATION_SERVICE_DATABASE=Notifications
AI_SERVICE_DATABASE=Ais

# --- Redis (required: non-empty password for container) ---
REDIS_PASSWORD=redis_dev_password

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Aspire Dashboard OTLP ---
ASPIRE_DASHBOARD_OTLP_API_KEY=dev-otlp-key

# --- JWT ---
JWT_BEARER_SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_BEARER_ISSUER=https://localhost
JWT_BEARER_AUDIENCE=https://localhost

# --- App ---
FRONTEND_URL=https://localhost

# --- AI (optional, for ai-service) ---
AI_PROVIDER=Gemini
GEMINI_API_KEY=
VEHICLE_SERVICE_BASE_URL=http://vehicle-service:8080

# --- Port overrides (optional) ---
# ASPIRE_DASHBOARD_UI_PORT=18888
# ASPIRE_DASHBOARD_OTLP_PORT=18889
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# RABBITMQ_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672
# GATEWAY_PORT=8080
# IDENTITY_SERVICE_PORT=7001
# VEHICLE_SERVICE_PORT=7002
# MEDIA_SERVICE_PORT=7003
# NOTIFICATION_SERVICE_PORT=7004
# AI_SERVICE_PORT=7005

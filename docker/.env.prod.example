# Copy to .env.prod and fill values. Used by: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

DOCKER_IMAGE_PREFIX=your-dockerhub-username
IMAGE_TAG=latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=verendar
IDENTITY_SERVICE_DATABASE=Identities
VEHICLE_SERVICE_DATABASE=Vehicles
MEDIA_SERVICE_DATABASE=Media
NOTIFICATION_SERVICE_DATABASE=Notifications
AI_SERVICE_DATABASE=Ais

REDIS_PASSWORD=change-me-redis-password

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me-rabbitmq-password

CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://admin.your-domain.com

JWT_BEARER_SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_BEARER_ISSUER=https://your-domain.com
JWT_BEARER_AUDIENCE=https://your-domain.com
JWT_BEARER_EXPIRATION_MINUTES=60
JWT_BEARER_REFRESH_TOKEN_EXPIRATION_DAYS=7

FRONTEND_URL=https://your-frontend-domain.com

MEDIA_S3_BUCKET_NAME=your-bucket-name
MEDIA_S3_REGION=ap-southeast-1
MEDIA_S3_ACCESS_KEY=
MEDIA_S3_SECRET_KEY=
MEDIA_S3_CLOUDFRONT_URL=

# Resend (email, Notification service)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-domain.com
RESEND_FROM_NAME=Verendar
# RESEND_REPLY_TO=
# RESEND_TIMEOUT=30
# RESEND_ENABLE_TRACKING=true
# RESEND_TEMPLATE_BASE_PATH=Templates/Email
# RESEND_ENABLE_TEMPLATE_CACHE=true
# RESEND_TEMPLATE_CACHE_EXPIRATION_MINUTES=60
# RESEND_USE_DATABASE_TEMPLATES=false

AI_PROVIDER=Gemini
GEMINI_API_KEY=
# Bedrock (khi AI_PROVIDER=Bedrock)
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
BEDROCK_REGION=us-east-1
VEHICLE_SERVICE_BASE_URL=http://vehicle-service:8080
IDENTITY_SERVICE_BASE_URL=http://identity-service:8080

# GATEWAY_PORT=8080
# IDENTITY_SERVICE_PORT=7001
# VEHICLE_SERVICE_PORT=7002
# MEDIA_SERVICE_PORT=7003
# NOTIFICATION_SERVICE_PORT=7004
# AI_SERVICE_PORT=7005
